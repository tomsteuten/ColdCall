# OS junk
Thumbs.db
Desktop.ini
.DS_Store

# Editors
.vscode/
.idea/
*.swp

# Dev tooling (never required at runtime — see CLAUDE.md)
node_modules/
npm-debug.log*

# Local scratch
*.local.*

# Disposable browser-audit output. Reusable preview harnesses in tools/*.html
# stay tracked; Chromium profiles and captured pixels never ship with the game.
tools/.audit-*/
tools/.verify*/
tools/audit-artifacts/
tools/audit-*.png
tools/verify-*.png

# Raw art-generation source triptychs — intermediate input, not shipped assets.
# Split into assets/generated/*.webp; kept locally as regeneration reference
# (see assets/generated/PROMPTS.md).
assets/triptichs/
